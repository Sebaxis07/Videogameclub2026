# ========================================
# Dashboard Club de Videojuegos — Backend
# ========================================

# Puerto del servidor Express
PORT=3000

# ID del Spreadsheet de Google Sheets
# Extraelo de la URL: https://docs.google.com/spreadsheets/d/<ID>/edit
SPREADSHEET_ID=17oLPkIhqpUzrLztAjfmCsJxdnnSvurqIi4Lfpyof7eg

# Ruta relativa al archivo JSON de la Service Account Key
# Descargalo desde Google Cloud Console > IAM > Service Accounts
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./thermal-land-457422-n0-8332d81797cb.json

# Rango de la hoja (incluye cabeceras)
# Ejemplo: Sheet1!A1:G200
SHEET_RANGE=ClubVideoJuegos!A1:G200

# Nombre de la hoja (para referencia)
SHEET_NAME=ClubVideojuegos

# Intervalo de sincronización en ms (30000 = 30 segundos)
# Intervalo de sincronización en ms (30000 = 30 segundos)
SYNC_INTERVAL_MS=30000

# ========================================
# MongoDB y Zero Trust (Migración Fase 1-4)
# ========================================

# Conexión a Base de datos (Local o Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/videogame_club

# Microsoft Entra ID (SSO / Azure AD)
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000

# Clave secreta para validar peticiones de Power Automate Webhooks
WEBHOOK_API_KEY=Club2026_1
